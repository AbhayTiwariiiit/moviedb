---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Discover, explore and find where to watch your favorite movies, TV shows, and web series. HD4U Movies — your premium movie discovery platform.", image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HEYM9PC7LB" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-HEYM9PC7LB');
    </script>
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO -->
    <title>{title} | HD4U Movies</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="hd4u movies, hd4u hab, hd4u movie, hd4u hub, hd4u movie hub, hd4u movies hub, hub hd4u, movie hd4u, hu hd4u, hd4u web series, hd4u movie review, hd4uhub movies, hd4uhub movie, 4k movies, top rated movies, bollywood, hollywood, streaming" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="HD4U Movies" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} | HD4U Movies`} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="HD4U Movies" />
    <meta property="og:locale" content="en_US" />
    {image && <meta property="og:image" content={image} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={`${title} | HD4U Movies`} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />

    <!-- Global Styles -->
    <style>
      @import "../styles/global.css";
    </style>
  </head>
  <body class="min-h-screen flex flex-col">
    <slot name="navbar" />
    <main class="flex-1">
      <slot />
    </main>
    <slot name="footer" />

    <!-- Adsterra Social Bar & Popunder -->
    <script is:inline src="https://pl30331064.effectivecpmnetwork.com/e9/e1/23/e9e123bb828fb281a8c0565cb656d51f.js"></script>
    <script is:inline src="https://pl30331066.effectivecpmnetwork.com/23/2a/2d/232a2d820feaab09d67627e3bfb4c814.js"></script>
  </body>
</html>
