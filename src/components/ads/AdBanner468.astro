---
// 468x60 Horizontal Banner
---
<div class="flex justify-center items-center my-4 overflow-hidden min-h-[60px] ad-slot-468">
  <script is:inline>
    (function() {
      var slots = document.querySelectorAll('.ad-slot-468');
      var container = slots[slots.length - 1];
      if (!container || container.dataset.loaded) return;
      container.dataset.loaded = 'true';
      var s1 = document.createElement('script');
      s1.text = "var atOptions = { 'key' : 'a5050d607c35ce51547e2456f108f36f', 'format' : 'iframe', 'height' : 60, 'width' : 468, 'params' : {} };";
      container.appendChild(s1);
      var s2 = document.createElement('script');
      s2.src = 'https://www.highperformanceformat.com/a5050d607c35ce51547e2456f108f36f/invoke.js';
      container.appendChild(s2);
    })();
  </script>
</div>
