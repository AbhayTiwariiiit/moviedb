---
// 160x600 Wide Skyscraper (Ideal for sidebar placements)
---
<div class="flex justify-center items-center my-6 overflow-hidden min-h-[600px] min-w-[160px] ad-slot-widesky">
  <script is:inline>
    (function() {
      var slots = document.querySelectorAll('.ad-slot-widesky');
      var container = slots[slots.length - 1];
      if (!container || container.dataset.loaded) return;
      container.dataset.loaded = 'true';
      var s1 = document.createElement('script');
      s1.text = "var atOptions = { 'key' : 'a18fb60112c31c4f67b24da91d6e5d09', 'format' : 'iframe', 'height' : 600, 'width' : 160, 'params' : {} };";
      container.appendChild(s1);
      var s2 = document.createElement('script');
      s2.src = 'https://www.highperformanceformat.com/a18fb60112c31c4f67b24da91d6e5d09/invoke.js';
      container.appendChild(s2);
    })();
  </script>
</div>
