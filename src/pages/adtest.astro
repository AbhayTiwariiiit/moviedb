---
import Layout from '../layouts/Layout.astro';
import AdBanner468 from '../components/ads/AdBanner468.astro';
---

<Layout title="Ad Test Page" description="Testing single ad implementation">
  <div class="max-w-[800px] mx-auto px-4 sm:px-6 py-12 text-center text-white">
    <h1 class="text-3xl font-bold mb-8">Ad Test Page (Single Ad)</h1>
    <p class="mb-8">This page only has exactly ONE ad tag to prevent any global variable collisions.</p>
    
    <div class="bg-gray-800 p-8 rounded-xl border border-gray-700">
      <AdBanner468 />
    </div>
  </div>
</Layout>
